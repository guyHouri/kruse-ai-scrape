# Copy to .env locally. In GitHub Actions, set these as repo Secrets.

# Gmail App Password (NOT your account password). Generate at:
# https://myaccount.google.com/apppasswords
# (Requires 2FA enabled on the Google account.)
GMAIL_USER=guyhouri.tech@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Optional overrides
# FROM_NAME=Kruse Daily
# LOCATION_LAT=31.7683
# LOCATION_LON=35.2137
# REPORT_TIME_ZONE=Asia/Jerusalem
# PRE_SUNRISE_MINUTES=60
# TOLERANCE_MINUTES=30
# SCRAPED_DATA_DIR=../twitter_to_md/data
# FORUM_DAILY_DIR=../forum_to_md/daily
# KRUSE_BLOG_SERIES_DIR=../private/kemono_to_md/processed_mds/blog_series
# KRUSE_BLOG_ARTICLES_PATH=../private/kemono_to_md/articles.json
# SUMMARY_WINDOW_HOURS=24
# INCLUDE_FORUM=true

# Required only for --use-ai / npm run build-ai
# ANTHROPIC_API_KEY=sk-ant-...
# KRUSE_AI_SELECTION_MIN_PRIORITY=3
# ANTHROPIC_MODEL=claude-haiku-4-5
# ANTHROPIC_MAX_TOKENS=20000

# Optional, for automatic website signup sync.
# Request the key with:
# curl -X GET https://formsubmit.co/api/get-apikey/guyhouri.tech@gmail.com
# Then save it locally or as GitHub secret FORMSUBMIT_API_KEY.
# FORMSUBMIT_API_KEY=...
