{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "KruseDailySummary",
  "type": "object",
  "required": ["headline_subtitle", "sections"],
  "additionalProperties": false,
  "properties": {
    "headline_subtitle": { "type": "string", "minLength": 4 },
    "sections": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["title", "cards"],
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string" },
          "cards": {
            "type": "array",
            "minItems": 1,
            "maxItems": 5,
            "items": {
              "type": "object",
              "required": ["tag", "lead", "body", "source_ids"],
              "additionalProperties": false,
              "properties": {
                "tag": { "type": "string" },
                "lead": { "type": "string" },
                "body": { "type": "string" },
                "concepts": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                },
                "source_quote": { "type": "string" },
                "source_ids": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  }
}
