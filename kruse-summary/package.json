{
  "name": "kruse-summary",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Daily Kruse Summary - reads scraped tweets, renders HTML, mails at 04:00 Israel time.",
  "homepage": "https://github.com/guyhouri/kruse-ai-scrape",
  "repository": {
    "type": "git",
    "url": "https://github.com/guyhouri/kruse-ai-scrape.git",
    "directory": "kruse-summary"
  },
  "author": "Guy Houri <guyhouri.tech@gmail.com>",
  "license": "MIT",
  "scripts": {
    "start": "node main.js",
    "build": "node main.js --build-only",
    "build-ai": "node main.js --build-only --use-ai",
    "build-input": "node code/build-input.js",
    "build-site": "node code/build-site.js",
    "test": "node --test tests/*.test.js",
    "verify-report": "node code/verify-report-interactions.js",
    "verify-report:all": "node code/verify-report-interactions.js --all",
    "sync-mailing-list": "node code/sync-mailing-list.js",
    "deploy-site": "npm run build-site && npx --yes gh-pages@latest -d site -b gh-pages -r https://github.com/guyHouri/kruse-ai-scrape.git --dotfiles -m \"Deploy Kruse report site\"",
    "force-send": "node main.js --force"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "dotenv": "^16.4.5",
    "nodemailer": "^7.0.7"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
