# Copy this file to `credentials.txt` and fill in your LinkedIn login.
# `credentials.txt` is gitignored and only used by the Playwright fallback
# path (when unauthenticated requests hit LinkedIn rate limits).
#
# Primary scrape path does NOT need login — Pulse articles are SEO-public.

LINKEDIN_USER=your-email@example.com
LINKEDIN_PASS=your-password
